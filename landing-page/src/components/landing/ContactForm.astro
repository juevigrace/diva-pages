---

---

<section class="py-16 md:py-24">
  <div class="container mx-auto px-6">
    <div class="mx-auto max-w-5xl">
      <div class="grid gap-12 md:grid-cols-2">
        <div>
          <h1 class="text-4xl font-bold tracking-tight md:text-5xl">Get in touch</h1>
          <p class="text-muted-foreground mt-4 text-lg">
            Have a question, feedback, or want to talk about your project? We'd love to hear from
            you.
          </p>
          <div class="mt-10 space-y-6">
            <div class="flex items-start gap-4">
              <div
                class="bg-primary/10 flex h-10 w-10 shrink-0 items-center justify-center rounded-lg"
              >
                <svg
                  class="text-primary h-5 w-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path>
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold">Email</p>
                <p class="text-muted-foreground text-sm">hello@diva.dev</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div
                class="bg-primary/10 flex h-10 w-10 shrink-0 items-center justify-center rounded-lg"
              >
                <svg
                  class="text-primary h-5 w-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                  ></path>
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold">Office</p>
                <p class="text-muted-foreground text-sm">
                  123 Market Street, San Francisco, CA 94105
                </p>
              </div>
            </div>
          </div>
        </div>
        <div class="border-border bg-card rounded-xl border p-8 shadow-sm">
          <form class="space-y-5">
            <div class="grid gap-5 sm:grid-cols-2">
              <div class="space-y-2">
                <label
                  class="text-sm leading-none font-medium peer-disabled:cursor-not-allowed peer-disabled:opacity-70"
                  for="first-name">First name</label
                >
                <input
                  id="first-name"
                  class="border-input placeholder:text-muted-foreground focus-visible:ring-ring flex h-9 w-full rounded-md border bg-transparent px-3 py-1 text-sm shadow-sm transition-colors file:border-0 file:bg-transparent file:text-sm file:font-medium focus-visible:ring-1 focus-visible:outline-none disabled:cursor-not-allowed disabled:opacity-50"
                  placeholder="Jane"
                />
              </div>
              <div class="space-y-2">
                <label
                  class="text-sm leading-none font-medium peer-disabled:cursor-not-allowed peer-disabled:opacity-70"
                  for="last-name">Last name</label
                >
                <input
                  id="last-name"
                  class="border-input placeholder:text-muted-foreground focus-visible:ring-ring flex h-9 w-full rounded-md border bg-transparent px-3 py-1 text-sm shadow-sm transition-colors file:border-0 file:bg-transparent file:text-sm file:font-medium focus-visible:ring-1 focus-visible:outline-none disabled:cursor-not-allowed disabled:opacity-50"
                  placeholder="Doe"
                />
              </div>
            </div>
            <div class="space-y-2">
              <label
                class="text-sm leading-none font-medium peer-disabled:cursor-not-allowed peer-disabled:opacity-70"
                for="email">Email</label
              >
              <input
                id="email"
                type="email"
                class="border-input placeholder:text-muted-foreground focus-visible:ring-ring flex h-9 w-full rounded-md border bg-transparent px-3 py-1 text-sm shadow-sm transition-colors file:border-0 file:bg-transparent file:text-sm file:font-medium focus-visible:ring-1 focus-visible:outline-none disabled:cursor-not-allowed disabled:opacity-50"
                placeholder="jane@example.com"
              />
            </div>
            <div class="space-y-2">
              <label
                class="text-sm leading-none font-medium peer-disabled:cursor-not-allowed peer-disabled:opacity-70"
                for="subject">Subject</label
              >
              <input
                id="subject"
                class="border-input placeholder:text-muted-foreground focus-visible:ring-ring flex h-9 w-full rounded-md border bg-transparent px-3 py-1 text-sm shadow-sm transition-colors file:border-0 file:bg-transparent file:text-sm file:font-medium focus-visible:ring-1 focus-visible:outline-none disabled:cursor-not-allowed disabled:opacity-50"
                placeholder="How can we help?"
              />
            </div>
            <div class="space-y-2">
              <label
                class="text-sm leading-none font-medium peer-disabled:cursor-not-allowed peer-disabled:opacity-70"
                for="message">Message</label
              >
              <textarea
                id="message"
                class="border-input placeholder:text-muted-foreground focus-visible:ring-ring flex min-h-[120px] w-full rounded-md border bg-transparent px-3 py-2 text-sm shadow-sm focus-visible:ring-1 focus-visible:outline-none disabled:cursor-not-allowed disabled:opacity-50"
                placeholder="Tell us about your project..."></textarea>
            </div>
            <button
              type="submit"
              class="bg-primary text-primary-foreground hover:bg-primary/90 inline-flex h-10 w-full items-center justify-center rounded-md px-4 py-2 text-sm font-medium shadow transition-colors"
              >Send message</button
            >
          </form>
        </div>
      </div>
    </div>
  </div>
</section>
