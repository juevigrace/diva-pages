---

---

<section class="relative overflow-hidden py-24 md:py-32 lg:py-40">
  <div class="container mx-auto px-6">
    <div class="mx-auto max-w-4xl text-center">
      <div
        class="border-border bg-muted text-muted-foreground mb-6 inline-flex items-center rounded-full border px-4 py-1.5 text-sm font-medium"
      >
        ✨ Now in public beta
      </div>
      <h1 class="text-4xl font-bold tracking-tight sm:text-5xl md:text-6xl lg:text-7xl">
        Build pages your users will love
      </h1>
      <p class="text-muted-foreground mx-auto mt-6 max-w-2xl text-lg md:text-xl">
        Diva Pages gives you beautiful, responsive page designs out of the box. Ship faster with a
        component library that feels like it was made for you.
      </p>
      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="/register"
          class="bg-primary text-primary-foreground hover:bg-primary/90 inline-flex h-11 items-center justify-center rounded-md px-8 py-2 text-sm font-medium shadow transition-colors"
          >Start building free</a
        >
        <a
          href="/contact"
          class="border-input bg-background hover:bg-accent hover:text-accent-foreground inline-flex h-11 items-center justify-center rounded-md border px-8 py-2 text-sm font-medium shadow-sm transition-colors"
          >Talk to sales</a
        >
      </div>
    </div>
    <div class="border-border bg-card mx-auto mt-20 max-w-5xl rounded-xl border p-2 shadow-lg">
      <div
        class="bg-muted text-muted-foreground flex aspect-video items-center justify-center rounded-lg"
      >
        <svg
          class="h-12 w-12"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"
          ></path>
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
      </div>
    </div>
  </div>
</section>
