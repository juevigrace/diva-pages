{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },

    "build": {
      "outputs": ["dist/**", ".astro/**"],
      "dependsOn": ["^build"]
    },
    "preview": {
      "cache": false
    },
    "stop": {
      "cache": false
    },
    "status": {
      "cache": false
    },
    "logs": {
      "cache": false
    }
  }
}
