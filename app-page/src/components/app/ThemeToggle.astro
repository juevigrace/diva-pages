---

<button
  id="theme-toggle"
  class="border-input bg-background hover:bg-accent hover:text-accent-foreground inline-flex h-9 w-9 cursor-pointer items-center justify-center rounded-md border shadow-sm transition-colors"
  aria-label="Toggle dark mode"
>
  <svg
    id="theme-icon"
    class="text-muted-foreground h-4 w-4"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path
      id="moon-path"
      d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
    ></path>
    <g id="sun-group" class="hidden">
      <circle cx="12" cy="12" r="4"></circle>
      <path d="M12 2v2"></path>
      <path d="M12 20v2"></path>
      <path d="M4.93 4.93l1.41 1.41"></path>
      <path d="M17.66 17.66l1.41 1.41"></path>
      <path d="M2 12h2"></path>
      <path d="M20 12h2"></path>
      <path d="M6.34 17.66l-1.41 1.41"></path>
      <path d="M19.07 4.93l-1.41 1.41"></path>
    </g>
  </svg>
</button>

<script>
  const toggle = document.getElementById('theme-toggle');
  const moonPath = document.getElementById('moon-path');
  const sunGroup = document.getElementById('sun-group');

  function updateIcon() {
    const isDark = document.documentElement.classList.contains('dark');
    if (moonPath && sunGroup) {
      if (isDark) {
        moonPath.classList.add('hidden');
        sunGroup.classList.remove('hidden');
      } else {
        moonPath.classList.remove('hidden');
        sunGroup.classList.add('hidden');
      }
    }
  }

  if (toggle) {
    toggle.addEventListener('click', () => {
      document.documentElement.classList.toggle('dark');
      updateIcon();
    });
  }

  updateIcon();
</script>
