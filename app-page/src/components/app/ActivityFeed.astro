---
const activities = [
  { user: 'Sarah Kim', action: 'created a new project', time: '2 minutes ago', initials: 'SK' },
  {
    user: 'Marcus Johnson',
    action: 'updated the dashboard',
    time: '15 minutes ago',
    initials: 'MJ',
  },
  { user: 'Priya Patel', action: 'deleted old records', time: '1 hour ago', initials: 'PP' },
  { user: 'Alex Morgan', action: 'invited 3 new members', time: '3 hours ago', initials: 'AM' },
  { user: 'Jordan Lee', action: 'completed onboarding', time: '5 hours ago', initials: 'JL' },
];
---

<div class="border-border bg-card rounded-xl border shadow-sm">
  <div class="border-border border-b px-6 py-4">
    <h3 class="font-semibold">Recent Activity</h3>
  </div>
  <div class="divide-border divide-y">
    {
      activities.map((activity) => (
        <div class="flex items-center gap-4 px-6 py-4">
          <div class="bg-primary/10 text-primary flex h-9 w-9 items-center justify-center rounded-full text-xs font-semibold">
            {activity.initials}
          </div>
          <div class="min-w-0 flex-1">
            <p class="text-sm">
              <span class="font-medium">{activity.user}</span>
              <span class="text-muted-foreground"> {activity.action}</span>
            </p>
          </div>
          <span class="text-muted-foreground shrink-0 text-xs">{activity.time}</span>
        </div>
      ))
    }
  </div>
  <div class="border-border border-t px-6 py-3">
    <a href="#" class="text-primary text-sm hover:underline">View all activity</a>
  </div>
</div>
