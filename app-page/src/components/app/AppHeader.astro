---
import ThemeToggle from '@components/app/ThemeToggle';
import UserMenuContent from '@components/app/UserMenuContent';
import MobileNav from '@components/app/MobileNav';

const currentPath = Astro.url.pathname;
const { session } = Astro.locals;
---

<header
  class="border-border bg-background/95 supports-[backdrop-filter]:bg-background/60 sticky top-0 z-30 h-16 border-b backdrop-blur"
>
  <div class="flex h-full items-center justify-between px-6 md:ml-64">
    <div class="flex items-center gap-3">
      <MobileNav currentPath={currentPath} client:load />
      <h2 class="text-lg font-semibold"><slot name="title" /></h2>
    </div>
    <div class="flex items-center gap-4">
      <ThemeToggle client:load />
      <UserMenuContent signedIn={!!session} client:load />
    </div>
  </div>
</header>
