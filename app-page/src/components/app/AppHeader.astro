---
import ThemeToggle from '@components/app/ThemeToggle';
import UserMenuContent from '@components/app/UserMenuContent';
import MobileNav from '@components/app/MobileNav';
import { t } from '@lib/i18n/t';

const currentPath = Astro.url.pathname;
const { session } = Astro.locals;
const lang = Astro.locals.lang;

const breadcrumbKey: Record<string, string> = {
  '/': 'dashboard',
  '/users': 'users',
  '/sessions': 'sessions',
  '/audit': 'auditLog',
  '/profile': 'profile',
  '/settings': 'settings',
  '/admin/permissions': 'permissions',
  '/admin/api': 'apiExplorer',
};

function getBreadcrumbs(path: string): { label: string; href: string }[] {
  const crumbs: { label: string; href: string }[] = [];
  const segments = path.split('/').filter(Boolean);
  let accum = '';
  for (const seg of segments) {
    accum += '/' + seg;
    const bk = breadcrumbKey[accum];
    const label = bk ? t(`nav.${bk}`, lang) : seg.charAt(0).toUpperCase() + seg.slice(1);
    crumbs.push({ label, href: accum });
  }
  if (crumbs.length === 0) crumbs.push({ label: t('nav.dashboard', lang), href: '/' });
  return crumbs;
}

const crumbs = getBreadcrumbs(currentPath);
---

<header
  class="border-border bg-background/95 supports-[backdrop-filter]:bg-background/60 sticky top-0 z-30 h-16 border-b backdrop-blur"
>
  <div class="flex h-full items-center justify-between px-6 md:ml-64">
    <div class="flex items-center gap-3">
      <MobileNav currentPath={currentPath} isAdmin={session?.role === 'ADMIN' || session?.role === 'MODERATOR'} lang={lang} client:visible />
      <div>
        <nav class="hidden items-center gap-1 text-sm text-muted-foreground md:flex">
          {
            crumbs.map((crumb, i) => (
              <>
                {i > 0 && <span class="mx-1">/</span>}
                <a
                  href={crumb.href}
                  class={`hover:text-foreground transition-colors ${i === crumbs.length - 1 ? 'text-foreground font-medium' : ''}`}
                >
                  {crumb.label}
                </a>
              </>
            ))
          }
        </nav>
        <h2 class="text-lg font-semibold md:hidden"><slot name="title" /></h2>
      </div>
    </div>
    <div class="flex items-center gap-4">
      <div class="hidden items-center gap-2 md:flex">
        <slot name="actions" />
      </div>
      <ThemeToggle client:idle />
      <UserMenuContent signedIn={!!session} lang={lang} client:idle />
    </div>
  </div>
</header>
