---
import ThemeToggle from '@components/app/ThemeToggle.astro';
import UserMenu from '@components/app/UserMenu.astro';
---

<header
  class="border-border bg-background/95 supports-[backdrop-filter]:bg-background/60 sticky top-0 z-30 h-16 border-b backdrop-blur"
>
  <div class="flex h-full items-center justify-between px-6 md:ml-64">
    <div>
      <h2 class="text-lg font-semibold"><slot name="title" /></h2>
    </div>
    <div class="flex items-center gap-4">
      <ThemeToggle />
      <UserMenu />
    </div>
  </div>
</header>
