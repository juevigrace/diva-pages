---
import { apiFetch } from '@api/lib/fetch';

const { session } = Astro.locals;
const token = session?.accessToken;

let totalUsers = '—';
let totalPages = 1;
let activeUsers = '—';
let totalSessions = '—';

try {
  if (token) {
    const usersRes = await apiFetch('/api/user/?page=1&limit=1', { token });
    if (usersRes.ok) {
      totalUsers = String(usersRes.json.data?.pagination_info?.total_items ?? '—');
      totalPages = usersRes.json.data?.pagination_info?.total_pages ?? 1;
      activeUsers = String(usersRes.json.data?.items?.length ?? '—');
    }
  }
} catch (_) {}

try {
  if (token && session?.userId) {
    const sessRes = await apiFetch(`/api/user/${session.userId}/sessions`, { token });
    if (sessRes.ok) {
      totalSessions = String((sessRes.json.data as any[])?.length ?? '—');
    }
  }
} catch (_) {}

const stats = [
  { label: 'Total Users', value: totalUsers, href: '/users' },
  { label: 'Users per Page', value: String(totalPages), href: '/users' },
  { label: 'Active Sessions', value: totalSessions, href: '/sessions' },
  { label: 'System Status', value: 'Online', href: '/admin/api' },
];
---

<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
  {stats.map((stat) => (
    <a
      href={stat.href}
      class="border-border bg-card hover:bg-accent/50 rounded-xl border p-6 shadow-sm transition-colors"
    >
      <p class="text-muted-foreground text-sm">{stat.label}</p>
      <div class="mt-2 flex items-baseline gap-2">
        <p class="text-3xl font-bold">{stat.value}</p>
      </div>
    </a>
  ))}
</div>
