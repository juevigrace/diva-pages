---
import { apiFetch } from '@api/lib/fetch';
import { t } from '@lib/i18n/t';

const { session } = Astro.locals;
const token = session?.accessToken;

let totalUsers = '—';
let totalPages = 1;
let totalSessions = '—';

try {
  if (token) {
    const usersRes = await apiFetch('/api/user/?page=1&limit=100', { token });
    if (usersRes.ok) {
      const items = (usersRes.json.data?.items || []).filter((u: any) => !u.deleted_at);
      totalUsers = String(items.length);
      totalPages = usersRes.json.data?.pagination_info?.total_pages ?? 1;
    }
  }
} catch (_) {}

try {
  if (token && session?.userId) {
    const sessRes = await apiFetch(`/api/user/${session.userId}/sessions`, { token });
    if (sessRes.ok) {
      const allSessions = (sessRes.json.data as any[]) || [];
      const now = Date.now();
      totalSessions = String(allSessions.filter((s) =>
        s.status?.toUpperCase() !== 'CLOSED' &&
        (!s.access_expires_at || now <= s.access_expires_at)
      ).length || '—');
    }
  }
} catch (_) {}

const stats = [
  { label: t('dashboard.activeUsers', Astro.locals.lang), value: totalUsers, href: '/users' },
  { label: t('dashboard.usersPerPage', Astro.locals.lang), value: String(totalPages), href: '/users' },
  { label: t('dashboard.activeSessions', Astro.locals.lang), value: totalSessions, href: '/sessions' },
  { label: t('dashboard.systemStatus', Astro.locals.lang), value: t('dashboard.online', Astro.locals.lang), href: '/admin/api' },
];
---

<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
  {stats.map((stat) => (
    <a
      href={stat.href}
      class="border-border bg-card hover:bg-accent/50 rounded-xl border p-6 shadow-sm transition-colors"
    >
      <p class="text-muted-foreground text-sm">{stat.label}</p>
      <div class="mt-2 flex items-baseline gap-2">
        <p class="text-3xl font-bold">{stat.value}</p>
      </div>
    </a>
  ))}
</div>
