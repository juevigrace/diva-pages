---
import Card from 'diva-ui/astro/Card.astro';
import { t } from '@lib/i18n/t';
const { lang = 'en' } = Astro.props;
---

<section class="border-border border-t py-20 md:py-28">
  <div class="container mx-auto px-6">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-bold tracking-tight md:text-4xl">
        {t('landing.featuresHeadline', lang)}
      </h2>
      <p class="text-muted-foreground mt-4 text-lg">
        {t('landing.featuresSubtitle', lang)}
      </p>
    </div>
    <div class="mt-14 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      <Card class="p-6">
        <div class="bg-primary/10 flex h-10 w-10 items-center justify-center rounded-lg">
          <svg
            class="text-primary h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"
            ></path>
          </svg>
        </div>
        <h3 class="mt-4 font-semibold">{t('landing.featureComponents', lang)}</h3>
        <p class="text-muted-foreground mt-2 text-sm">
          {t('landing.featureComponentsDesc', lang)}
        </p>
      </Card>
      <Card class="p-6">
        <div class="bg-primary/10 flex h-10 w-10 items-center justify-center rounded-lg">
          <svg
            class="text-primary h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"
            ></path>
          </svg>
        </div>
        <h3 class="mt-4 font-semibold">{t('landing.featureThemes', lang)}</h3>
        <p class="text-muted-foreground mt-2 text-sm">
          {t('landing.featureThemesDesc', lang)}
        </p>
      </Card>
      <Card class="p-6">
        <div class="bg-primary/10 flex h-10 w-10 items-center justify-center rounded-lg">
          <svg
            class="text-primary h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"
            ></path>
          </svg>
        </div>
        <h3 class="mt-4 font-semibold">{t('landing.featureFast', lang)}</h3>
        <p class="text-muted-foreground mt-2 text-sm">
          {t('landing.featureFastDesc', lang)}
        </p>
      </Card>
      <Card class="p-6">
        <div class="bg-primary/10 flex h-10 w-10 items-center justify-center rounded-lg">
          <svg
            class="text-primary h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
            ></path>
          </svg>
        </div>
        <h3 class="mt-4 font-semibold">{t('landing.featureSecure', lang)}</h3>
        <p class="text-muted-foreground mt-2 text-sm">
          {t('landing.featureSecureDesc', lang)}
        </p>
      </Card>
      <Card class="p-6">
        <div class="bg-primary/10 flex h-10 w-10 items-center justify-center rounded-lg">
          <svg
            class="text-primary h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
            ></path>
          </svg>
        </div>
        <h3 class="mt-4 font-semibold">{t('landing.featureTeam', lang)}</h3>
        <p class="text-muted-foreground mt-2 text-sm">
          {t('landing.featureTeamDesc', lang)}
        </p>
      </Card>
      <Card class="p-6">
        <div class="bg-primary/10 flex h-10 w-10 items-center justify-center rounded-lg">
          <svg
            class="text-primary h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
            ></path>
          </svg>
        </div>
        <h3 class="mt-4 font-semibold">{t('landing.featureTested', lang)}</h3>
        <p class="text-muted-foreground mt-2 text-sm">
          {t('landing.featureTestedDesc', lang)}
        </p>
      </Card>
    </div>
  </div>
</section>
