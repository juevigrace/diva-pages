---
import { t } from '@lib/i18n/t';
const { lang = 'en' } = Astro.props;
const team = [
  { name: 'Alex Chen', role: 'CEO & Co-founder', initials: 'AC' },
  { name: 'Sarah Kim', role: 'CTO & Co-founder', initials: 'SK' },
  { name: 'Marcus Johnson', role: 'Head of Design', initials: 'MJ' },
  { name: 'Priya Patel', role: 'Head of Engineering', initials: 'PP' },
];
---

<section class="py-16 md:py-24">
  <div class="container mx-auto px-6">
    <div class="mx-auto max-w-3xl">
      <h1 class="text-4xl font-bold tracking-tight md:text-5xl">{t('landing.aboutTitle', lang)}</h1>
      <p class="text-muted-foreground mt-6 text-lg leading-relaxed">
        {t('landing.aboutP1', lang)}
      </p>
      <p class="text-muted-foreground mt-4 text-lg leading-relaxed">
        {t('landing.aboutP2', lang)}
      </p>
    </div>

    <div class="mx-auto mt-20 max-w-3xl">
      <h2 class="text-2xl font-bold tracking-tight">{t('landing.ourTeam', lang)}</h2>
      <div class="mt-8 grid gap-6 sm:grid-cols-2">
        {
          team.map((member) => (
            <div class="border-border bg-card flex items-center gap-4 rounded-xl border p-4 shadow-sm">
              <div class="bg-primary/10 text-primary flex h-12 w-12 items-center justify-center rounded-full text-sm font-semibold">
                {member.initials}
              </div>
              <div>
                <p class="text-sm font-semibold">{member.name}</p>
                <p class="text-muted-foreground text-sm">{member.role}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <div class="mx-auto mt-20 max-w-3xl">
      <h2 class="text-2xl font-bold tracking-tight">{t('landing.ourValues', lang)}</h2>
      <div class="mt-8 grid gap-6 sm:grid-cols-2">
        <div class="border-border bg-card rounded-xl border p-6 shadow-sm">
          <h3 class="font-semibold">{t('landing.valueSimplicity', lang)}</h3>
          <p class="text-muted-foreground mt-2 text-sm">
            {t('landing.valueSimplicityDesc', lang)}
          </p>
        </div>
        <div class="border-border bg-card rounded-xl border p-6 shadow-sm">
          <h3 class="font-semibold">{t('landing.valuePerformance', lang)}</h3>
          <p class="text-muted-foreground mt-2 text-sm">
            {t('landing.valuePerformanceDesc', lang)}
          </p>
        </div>
        <div class="border-border bg-card rounded-xl border p-6 shadow-sm">
          <h3 class="font-semibold">{t('landing.valueAccessibility', lang)}</h3>
          <p class="text-muted-foreground mt-2 text-sm">
            {t('landing.valueAccessibilityDesc', lang)}
          </p>
        </div>
        <div class="border-border bg-card rounded-xl border p-6 shadow-sm">
          <h3 class="font-semibold">{t('landing.valueOpenness', lang)}</h3>
          <p class="text-muted-foreground mt-2 text-sm">
            {t('landing.valueOpennessDesc', lang)}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
