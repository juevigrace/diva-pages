---
import Button from 'diva-ui/astro/Button.astro';
import { t } from '@lib/i18n/t';
const { lang = 'en' } = Astro.props;
---

<section class="border-border border-t py-20 md:py-28">
  <div class="container mx-auto px-6">
    <div
      class="bg-primary/5 border-border mx-auto max-w-4xl rounded-2xl border p-12 text-center md:p-16"
    >
      <h2 class="text-3xl font-bold tracking-tight md:text-4xl">{t('landing.ctaHeadline', lang)}</h2>
      <p class="text-muted-foreground mx-auto mt-4 max-w-2xl text-lg">
        {t('landing.ctaSubtitle', lang)}
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <Button href="/signUp" variant="default" size="lg" class="h-11">{t('landing.getStartedFree', lang)}</Button>
        <Button href="/contact" variant="outline" size="lg" class="h-11">{t('landing.scheduleDemo', lang)}</Button>
      </div>
    </div>
  </div>
</section>
