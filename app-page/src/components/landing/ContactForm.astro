---
import ContactFormWidget from './ContactFormWidget';
---

<section class="py-16 md:py-24">
  <div class="container mx-auto px-6">
    <div class="mx-auto max-w-5xl">
      <div class="grid gap-12 md:grid-cols-2">
        <div>
          <h1 class="text-4xl font-bold tracking-tight md:text-5xl">Get in touch</h1>
          <p class="text-muted-foreground mt-4 text-lg">
            Have a question, feedback, or want to talk about your project? We'd love to hear from
            you.
          </p>
          <div class="mt-10 space-y-6">
            <div class="flex items-start gap-4">
              <div
                class="bg-primary/10 flex h-10 w-10 shrink-0 items-center justify-center rounded-lg"
              >
                <svg
                  class="text-primary h-5 w-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path>
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold">Email</p>
                <p class="text-muted-foreground text-sm">hello@diva.dev</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div
                class="bg-primary/10 flex h-10 w-10 shrink-0 items-center justify-center rounded-lg"
              >
                <svg
                  class="text-primary h-5 w-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                  ></path>
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold">Office</p>
                <p class="text-muted-foreground text-sm">
                  123 Market Street, San Francisco, CA 94105
                </p>
              </div>
            </div>
          </div>
        </div>
        <div class="border-border bg-card rounded-xl border p-8 shadow-sm">
          <ContactFormWidget client:load />
        </div>
      </div>
    </div>
  </div>
</section>
