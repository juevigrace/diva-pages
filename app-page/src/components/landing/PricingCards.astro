---
const plans = [
  {
    name: 'Starter',
    price: '$0',
    description: 'Perfect for getting started',
    features: ['3 projects', 'Basic components', 'Community support', '1 team member'],
    cta: 'Get started free',
    ctaHref: '/signUp',
    highlighted: false,
  },
  {
    name: 'Pro',
    price: '$29',
    description: 'For growing teams',
    features: [
      'Unlimited projects',
      'All components',
      'Priority support',
      'Up to 10 team members',
      'Custom themes',
    ],
    cta: 'Start free trial',
    ctaHref: '/signUp',
    highlighted: true,
  },
  {
    name: 'Enterprise',
    price: '$99',
    description: 'For large organizations',
    features: [
      'Everything in Pro',
      'Custom components',
      'Dedicated support',
      'Unlimited team members',
      'SLA guarantee',
      'On-premise deployment',
    ],
    cta: 'Contact sales',
    ctaHref: '/contact',
    highlighted: false,
  },
];
---

<section id="pricing" class="border-border border-t py-20 md:py-28">
  <div class="container mx-auto px-6">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-bold tracking-tight md:text-4xl">Simple, transparent pricing</h2>
      <p class="text-muted-foreground mt-4 text-lg">No hidden fees. No surprise charges.</p>
    </div>
    <div class="mt-14 grid gap-8 md:grid-cols-3">
      {
        plans.map((plan) => (
          <div
            class={`rounded-xl border ${plan.highlighted ? 'border-primary bg-card ring-primary shadow-lg ring-1' : 'border-border bg-card shadow-sm'} p-8`}
          >
            {plan.highlighted && (
              <div class="bg-primary/10 text-primary mb-4 inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold">
                Most popular
              </div>
            )}
            <h3 class="text-lg font-semibold">{plan.name}</h3>
            <p class="text-muted-foreground mt-1 text-sm">{plan.description}</p>
            <div class="mt-6 flex items-baseline gap-1">
              <span class="text-4xl font-bold">{plan.price}</span>
              {plan.price !== '$0' && <span class="text-muted-foreground text-sm">/month</span>}
            </div>
            <ul class="mt-8 space-y-3">
              {plan.features.map((feature) => (
                <li class="flex items-center gap-3 text-sm">
                  <svg
                    class="text-primary h-4 w-4 shrink-0"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2.5"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>
            <a
              href={plan.ctaHref}
              class={`mt-8 inline-flex h-10 w-full items-center justify-center rounded-md text-sm font-medium shadow transition-colors ${plan.highlighted ? 'bg-primary text-primary-foreground hover:bg-primary/90' : 'border-input bg-background hover:bg-accent hover:text-accent-foreground border'}`}
            >
              {plan.cta}
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>
