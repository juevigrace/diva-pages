---
import Button from 'diva-ui/astro/Button.astro';
import Badge from 'diva-ui/astro/Badge.astro';
import Card from 'diva-ui/astro/Card.astro';
import { t } from '@lib/i18n/t';
const { lang = 'en' } = Astro.props;
const plans = [
  {
    name: t('landing.planStarter', lang),
    price: '$0',
    description: t('landing.planStarterDesc', lang),
    features: [t('landing.planStarterF1', lang), t('landing.planStarterF2', lang), t('landing.planStarterF3', lang), t('landing.planStarterF4', lang)],
    cta: t('landing.planStarterCta', lang),
    ctaHref: '/signUp',
    highlighted: false,
  },
  {
    name: t('landing.planPro', lang),
    price: '$29',
    description: t('landing.planProDesc', lang),
    features: [
      t('landing.planProF1', lang),
      t('landing.planProF2', lang),
      t('landing.planProF3', lang),
      t('landing.planProF4', lang),
      t('landing.planProF5', lang),
    ],
    cta: t('landing.planProCta', lang),
    ctaHref: '/signUp',
    highlighted: true,
  },
  {
    name: t('landing.planEnterprise', lang),
    price: '$99',
    description: t('landing.planEnterpriseDesc', lang),
    features: [
      t('landing.planEnterpriseF1', lang),
      t('landing.planEnterpriseF2', lang),
      t('landing.planEnterpriseF3', lang),
      t('landing.planEnterpriseF4', lang),
      t('landing.planEnterpriseF5', lang),
      t('landing.planEnterpriseF6', lang),
    ],
    cta: t('landing.planEnterpriseCta', lang),
    ctaHref: '/contact',
    highlighted: false,
  },
];
---

<section id="pricing" class="border-border border-t py-20 md:py-28">
  <div class="container mx-auto px-6">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-bold tracking-tight md:text-4xl">{t('landing.pricingTitle', lang)}</h2>
      <p class="text-muted-foreground mt-4 text-lg">{t('landing.pricingSubtitle', lang)}</p>
    </div>
    <div class="mt-14 grid gap-8 md:grid-cols-3">
      {
        plans.map((plan) => (
          <Card
            class={`${plan.highlighted ? 'border-primary ring-primary shadow-lg ring-1' : 'border-border shadow-sm'} p-8`}
          >
            {plan.highlighted && (
              <Badge variant="default" class="bg-primary/10 text-primary border-0">
                {t('landing.mostPopular', lang)}
              </Badge>
            )}
            <h3 class="text-lg font-semibold">{plan.name}</h3>
            <p class="text-muted-foreground mt-1 text-sm">{plan.description}</p>
            <div class="mt-6 flex items-baseline gap-1">
              <span class="text-4xl font-bold">{plan.price}</span>
              {plan.price !== '$0' && <span class="text-muted-foreground text-sm">{t('landing.perMonth', lang)}</span>}
            </div>
            <ul class="mt-8 space-y-3">
              {plan.features.map((feature) => (
                <li class="flex items-center gap-3 text-sm">
                  <svg
                    class="text-primary h-4 w-4 shrink-0"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2.5"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>
            <Button href={plan.ctaHref} variant={plan.highlighted ? 'default' : 'outline'} class="w-full">
              {plan.cta}
            </Button>
          </Card>
        ))
      }
    </div>
  </div>
</section>
