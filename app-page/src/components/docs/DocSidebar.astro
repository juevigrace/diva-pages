---
import { t } from '@lib/i18n/t';
import { docSectionKey as sectionKey } from '@lib/i18n/nav-keys';

const { lang = 'en' } = Astro.props;

const linkKey: Record<string, string> = {
  'Installation': 'gettingStarted',
  'Quick Start': 'gettingStarted',
  'Project Structure': 'gettingStarted',
  'Overview': 'components',
  'Button': 'components',
  'Card': 'components',
  'Forms': 'components',
  'Navigation': 'components',
  'Overlays': 'components',
  'Component Props': 'api',
  'Events': 'api',
  'TypeScript Types': 'api',
};

const sections = [
  {
    title: 'Getting Started',
    links: [
      { href: '/docs/getting-started', label: 'Installation' },
      { href: '/docs/getting-started#quick-start', label: 'Quick Start' },
      { href: '/docs/getting-started#project-structure', label: 'Project Structure' },
    ],
  },
  {
    title: 'Components',
    links: [
      { href: '/docs/components', label: 'Overview' },
      { href: '/docs/components#button', label: 'Button' },
      { href: '/docs/components#card', label: 'Card' },
      { href: '/docs/components#forms', label: 'Forms' },
      { href: '/docs/components#navigation', label: 'Navigation' },
      { href: '/docs/components#overlay', label: 'Overlays' },
    ],
  },
  {
    title: 'API Reference',
    links: [
      { href: '/docs/api', label: 'Overview' },
      { href: '/docs/api#props', label: 'Component Props' },
      { href: '/docs/api#events', label: 'Events' },
      { href: '/docs/api#types', label: 'TypeScript Types' },
    ],
  },
];
---

<aside class="border-border w-64 shrink-0 border-r">
  <nav class="sticky top-16 p-6">
    <div class="mb-6">
      <a href="/docs" class="flex items-center gap-2 text-lg font-bold">
        <span
          class="bg-primary text-primary-foreground flex h-7 w-7 items-center justify-center rounded-md text-xs font-bold"
          >D</span
        >
        {t('docs.title', lang)}
      </a>
    </div>
    {
      sections.map((section) => {
        const sk = sectionKey[section.title] || section.title.toLowerCase().replace(/\s+/g, '');
        return (
          <div class="mb-6">
            <h4 class="text-muted-foreground mb-2 text-xs font-semibold tracking-wider uppercase">
              {t(`docs.${sk}`, lang)}
            </h4>
            <ul class="space-y-1">
              {section.links.map((link) => {
                const lk = linkKey[link.label] || sk;
                return (
                  <li>
                    <a
                      href={link.href}
                      class="text-muted-foreground hover:bg-accent hover:text-accent-foreground block rounded-md px-3 py-1.5 text-sm transition-colors"
                    >
                      {t(`docs.${lk}`, lang)}
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        );
      })
    }
  </nav>
</aside>
