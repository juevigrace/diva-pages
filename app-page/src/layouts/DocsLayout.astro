---
import '../styles/global.css';
import Layout from './Layout.astro';
import DocSidebar from '../components/docs/DocSidebar.astro';
import SearchBar from '../components/docs/SearchBar.astro';

export interface Props {
  title?: string;
  description?: string;
}

const { title = 'Docs — Diva', description } = Astro.props;
---

<Layout title={title} description={description}>
  <div class="flex min-h-screen" transition:animate="slide">
    <DocSidebar />
    <div class="flex-1">
      <div
        class="border-border bg-background/95 supports-[backdrop-filter]:bg-background/60 sticky top-0 z-30 border-b backdrop-blur"
      >
        <div class="mx-auto max-w-4xl px-6 py-3">
          <SearchBar />
        </div>
      </div>
      <div class="flex">
        <main class="min-w-0 flex-1 px-6 py-10 md:px-10">
          <slot />
        </main>
      </div>
    </div>
  </div>
</Layout>
