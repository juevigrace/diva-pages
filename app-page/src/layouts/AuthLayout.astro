---
import '@styles/global.css';
import Layout from '@layouts/Layout.astro';
import { t } from '@lib/i18n/t';

export interface Props {
  title?: string;
  description?: string;
}

const { title = 'Diva', description } = Astro.props;
const lang = Astro.locals.lang || 'en';
---

<Layout title={title} description={description}>
  <div class="flex min-h-screen flex-col">
    <header class="border-border bg-background/95 supports-[backdrop-filter]:bg-background/60 sticky top-0 z-50 w-full border-b backdrop-blur">
      <div class="container mx-auto flex h-16 items-center justify-between px-6">
        <a href="/home" class="flex items-center gap-2 text-xl font-bold">
          <span
            class="bg-primary text-primary-foreground flex h-8 w-8 items-center justify-center rounded-lg text-sm font-bold"
            >D</span
          >
          Diva
        </a>
        <a
          href="/home"
          class="text-muted-foreground hover:text-foreground text-sm font-medium transition-colors"
        >
          &larr; {t('common.back', lang)}
        </a>
      </div>
    </header>
    <main class="flex flex-1 items-center justify-center px-4 py-12" transition:animate="slide">
      <slot />
    </main>
  </div>
</Layout>
