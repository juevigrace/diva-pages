---
import '../styles/global.css';
import Layout from 'diva-ui/layouts/Layout.astro';

export interface Props {
  title?: string;
}

const { title = 'Diva' } = Astro.props;
---

<Layout title={title}>
  <div class="flex min-h-screen items-center justify-center px-4 py-12">
    <slot />
  </div>
</Layout>
