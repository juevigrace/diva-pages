---
import '../styles/global.css';
import Layout from 'diva-ui/layouts/Layout.astro';
import AppSidebar from '../components/app/AppSidebar.astro';
import AppHeader from '../components/app/AppHeader.astro';

export interface Props {
  title?: string;
  heading?: string;
}

const { title = 'App — Diva', heading = '' } = Astro.props;
---

<Layout title={title}>
  <AppSidebar />
  <div class="md:pl-64">
    <AppHeader>
      <Fragment slot="title">{heading}</Fragment>
    </AppHeader>
    <main class="p-6">
      <slot />
    </main>
  </div>
</Layout>
