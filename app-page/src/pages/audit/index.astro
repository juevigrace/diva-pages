---
import AppLayout from '@layouts/AppLayout.astro';
import AuditLog from '@components/app/AuditLog';

import { t } from '@lib/i18n/t';

const { session } = Astro.locals;
const isVerified = session!.isVerified;
---

<AppLayout title={t('page.audit.title', Astro.locals.lang)} heading="Audit Log" description={t('page.audit.desc', Astro.locals.lang)}>
  <AuditLog isVerified={isVerified} lang={Astro.locals.lang} client:load />
</AppLayout>
