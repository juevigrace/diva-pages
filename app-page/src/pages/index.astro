---
import AppLayout from '@layouts/AppLayout.astro';
import StatsCards from '@components/app/StatsCards.astro';
import ActivityFeed from '@components/app/ActivityFeed';
import { t } from '@lib/i18n/t';

const { session } = Astro.locals;
const uid = session!.userId;
const isVerified = session!.isVerified;
---

<AppLayout
  title={t('page.dashboard.title', Astro.locals.lang)}
  heading="Dashboard"
  description={t('page.dashboard.desc', Astro.locals.lang)}
>
  <StatsCards />

  <div class="mt-8 grid gap-6 lg:grid-cols-2">
    <ActivityFeed uid={uid} isVerified={isVerified} lang={Astro.locals.lang} client:visible />
    <div class="border-border bg-card rounded-xl border p-6 shadow-sm">
      <h3 class="font-semibold">{t('dashboard.quickActions', Astro.locals.lang)}</h3>
      <div class="mt-4 space-y-3">
        <a
          href="/users"
          class="border-border hover:bg-accent flex items-center gap-3 rounded-lg border p-4 transition-colors"
        >
          <div class="bg-primary/10 flex h-10 w-10 items-center justify-center rounded-lg">
            <svg
              class="text-primary h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"
              ></path>
            </svg>
          </div>
          <div>
            <p class="text-sm font-medium">{t('dashboard.inviteTeam', Astro.locals.lang)}</p>
            <p class="text-muted-foreground text-xs">{t('dashboard.inviteTeamDesc', Astro.locals.lang)}</p>
          </div>
        </a>
        <a
          href="/settings"
          class="border-border hover:bg-accent flex items-center gap-3 rounded-lg border p-4 transition-colors"
        >
          <div class="bg-primary/10 flex h-10 w-10 items-center justify-center rounded-lg">
            <svg
              class="text-primary h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <div>
            <p class="text-sm font-medium">{t('dashboard.configureSettings', Astro.locals.lang)}</p>
            <p class="text-muted-foreground text-xs">{t('dashboard.configureSettingsDesc', Astro.locals.lang)}</p>
          </div>
        </a>
        <a
          href="/profile"
          class="border-border hover:bg-accent flex items-center gap-3 rounded-lg border p-4 transition-colors"
        >
          <div class="bg-primary/10 flex h-10 w-10 items-center justify-center rounded-lg">
            <svg
              class="text-primary h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
          </div>
          <div>
            <p class="text-sm font-medium">{t('dashboard.editProfile', Astro.locals.lang)}</p>
            <p class="text-muted-foreground text-xs">{t('dashboard.editProfileDesc', Astro.locals.lang)}</p>
          </div>
        </a>
      </div>
    </div>
  </div>
</AppLayout>
