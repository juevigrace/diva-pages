---
import AppLayout from '@layouts/AppLayout.astro';
import SessionsManager from '@components/app/SessionsManager';
import { apiFetch } from '@api/lib/fetch';
import { t } from '@lib/i18n/t';

const { session } = Astro.locals;
const uid = session!.userId;
const isVerified = session!.isVerified;

let sessions: Record<string, any>[] | null = null;

if (isVerified) {
  try {
    const res = await apiFetch(`/api/user/${uid}/sessions`, { token: session!.accessToken });
    if (res.ok) {
      sessions = res.json.data;
    }
  } catch (_) {}
}
---

<AppLayout title={t('page.sessions.title', Astro.locals.lang)} heading="Sessions" description={t('page.sessions.desc', Astro.locals.lang)}>
  <SessionsManager uid={uid} initialSessions={sessions} currentSessionId={session!.sessionId} isVerified={isVerified} lang={Astro.locals.lang} client:load />
</AppLayout>
