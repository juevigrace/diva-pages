---
import AppLayout from '@layouts/AppLayout.astro';
import ProfileForms from '@components/app/ProfileForms';
import { apiFetch } from '@api/lib/fetch';
import { fetchCurrentUser } from '@api/lib/user';
import { t } from '@lib/i18n/t';

const { session } = Astro.locals;
const uid = session!.userId;

const { user, isVerified } = await fetchCurrentUser(uid, session!.accessToken);

let profile: Record<string, any> | null = null;

if (isVerified) {
  try {
    const profileRes = await apiFetch(`/api/user/${uid}/profile`, { token: session!.accessToken });
    if (profileRes.ok) {
      profile = profileRes.json.data;
    }
  } catch (_) {}
}
---

<AppLayout
  title={t('page.profile.title', Astro.locals.lang)}
  heading="Profile"
  description={t('page.profile.desc', Astro.locals.lang)}
>
  <ProfileForms uid={uid} user={user} profile={profile} isVerified={isVerified} lang={Astro.locals.lang} client:load />
</AppLayout>
