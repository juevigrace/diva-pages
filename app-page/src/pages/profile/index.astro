---
import AppLayout from '@layouts/AppLayout.astro';
import ProfileForms from '@components/app/ProfileForms';
import { API_BASE_URL } from 'astro:env/server';

const { session } = Astro.locals;
const uid = session!.userId;

let user: Record<string, any> | null = null;
let profile: Record<string, any> | null = null;

try {
  const userRes = await fetch(`${API_BASE_URL}/api/user/${uid}`, {
    headers: {
      'Content-Type': 'application/json',
      Authorization: `Bearer ${session!.accessToken}`,
    },
  });
  if (userRes.ok) {
    const userJson = await userRes.json();
    user = userJson.data;
  }
} catch (_) {}

try {
  const profileRes = await fetch(`${API_BASE_URL}/api/user/${uid}/profile`, {
    headers: {
      'Content-Type': 'application/json',
      Authorization: `Bearer ${session!.accessToken}`,
    },
  });
  if (profileRes.ok) {
    const profileJson = await profileRes.json();
    profile = profileJson.data;
  }
} catch (_) {}
---

<AppLayout
  title="Profile — Diva"
  heading="Profile"
  description="Manage your Diva Pages profile and personal information."
>
  <ProfileForms uid={uid} user={user} profile={profile} client:load />
</AppLayout>
