---
import Layout from '@layouts/Layout.astro';
import VerificationFlow from '@components/auth/VerificationFlow';

const action = Astro.url.searchParams.get('action') || 'USER_VERIFICATION';
const email = Astro.url.searchParams.get('email') || '';
---

<Layout title="Verify — Diva" description="Email verification">
  <div class="flex min-h-screen items-center justify-center px-4">
    <VerificationFlow action={action} email={email} client:load />
  </div>
</Layout>
