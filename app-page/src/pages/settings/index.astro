---
import AppLayout from '@layouts/AppLayout.astro';
import SettingsContent from '@components/app/SettingsContent';
import { apiFetch } from '@api/lib/fetch';
import { t } from '@lib/i18n/t';

const { session } = Astro.locals;
const uid = session!.userId;
const isVerified = session!.isVerified;

let preferencesList: Record<string, any>[] | null = null;

if (isVerified) {
  try {
    const prefRes = await apiFetch(`/api/user/${uid}/preferences`, { token: session!.accessToken });
    if (prefRes.ok) {
      preferencesList = prefRes.json.data;
    }
  } catch (_) {}
}

const preferences = preferencesList && preferencesList.length > 0 ? preferencesList[0] : null;
---

<AppLayout
  title={t('page.settings.title', Astro.locals.lang)}
  heading="Settings"
  description={t('page.settings.desc', Astro.locals.lang)}
>
  <SettingsContent uid={uid} initialPreferences={preferences} isVerified={isVerified} lang={Astro.locals.lang} client:load />
</AppLayout>
