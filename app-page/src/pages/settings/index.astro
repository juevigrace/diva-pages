---
import AppLayout from '@layouts/AppLayout.astro';
import SettingsContent from '@components/app/SettingsContent';
import { API_BASE_URL } from 'astro:env/server';

const { session } = Astro.locals;
const uid = session!.userId;

let preferencesList: Record<string, any>[] | null = null;
let sessions: Record<string, any>[] | null = null;

try {
  const prefRes = await fetch(`${API_BASE_URL}/api/user/${uid}/preferences`, {
    headers: {
      'Content-Type': 'application/json',
      Authorization: `Bearer ${session!.accessToken}`,
    },
  });
  if (prefRes.ok) {
    const json = await prefRes.json();
    preferencesList = json.data;
  }
} catch (_) {}

try {
  const sessRes = await fetch(`${API_BASE_URL}/api/user/${uid}/sessions`, {
    headers: {
      'Content-Type': 'application/json',
      Authorization: `Bearer ${session!.accessToken}`,
    },
  });
  if (sessRes.ok) {
    const json = await sessRes.json();
    sessions = json.data;
  }
} catch (_) {}

const preferences = preferencesList && preferencesList.length > 0 ? preferencesList[0] : null;
---

<AppLayout
  title="Settings — Diva"
  heading="Settings"
  description="Manage your Diva Pages workspace settings."
>
  <SettingsContent
    uid={uid}
    initialPreferences={preferences}
    initialSessions={sessions}
    client:load
  />
</AppLayout>
