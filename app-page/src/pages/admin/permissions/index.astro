---
import AppLayout from '@layouts/AppLayout.astro';
import PermissionsManager from '@components/app/PermissionsManager';
import { apiFetch } from '@api/lib/fetch';
import { fetchCurrentUser } from '@api/lib/user';
import { t } from '@lib/i18n/t';

const { session } = Astro.locals;
const uid = session!.userId;

const { isVerified } = await fetchCurrentUser(uid, session!.accessToken);

const url = new URL(Astro.request.url);
const currentPage = parseInt(url.searchParams.get('page') || '1', 10);
const limit = 20;

let permissionsData: Record<string, any>[] = [];
let totalItems = 0;
let totalPages = 1;
let loadError = false;
let currentUserRole = '';

try {
  const userRes = await apiFetch(`/api/user/${uid}`, { token: session!.accessToken });
  if (userRes.ok) {
    currentUserRole = userRes.json.data?.role || '';
  }
} catch (_) {}

if (isVerified) {
  try {
    const res = await apiFetch(`/api/permissions/?page=${currentPage}&limit=${limit}`, { token: session!.accessToken });
    if (res.ok) {
      permissionsData = res.json.data?.items || [];
      totalItems = res.json.data?.pagination_info?.total_items || 0;
      totalPages = res.json.data?.pagination_info?.total_pages || 1;
    } else {
      loadError = true;
    }
  } catch (_) {
    loadError = true;
  }
}
---

<AppLayout
  title={t('page.permissions.title', Astro.locals.lang)}
  heading="Permissions"
  description={t('page.permissions.desc', Astro.locals.lang)}
>
  <PermissionsManager
    initialPermissions={permissionsData}
    initialPage={currentPage}
    initialTotalPages={totalPages}
    initialTotalItems={totalItems}
    loadError={loadError}
    currentUserRole={currentUserRole}
    isVerified={isVerified}
    lang={Astro.locals.lang}
    client:load
  />
</AppLayout>
