---
import AppLayout from '@layouts/AppLayout.astro';
import PermissionsManager from '@components/app/PermissionsManager';
import { API_BASE_URL } from 'astro:env/server';

const { session } = Astro.locals;
const uid = session!.userId;

const url = new URL(Astro.request.url);
const currentPage = parseInt(url.searchParams.get('page') || '1', 10);
const limit = 20;

let permissionsData: Record<string, any>[] = [];
let totalItems = 0;
let totalPages = 1;
let loadError = false;

try {
  const res = await fetch(`${API_BASE_URL}/api/permissions/?page=${currentPage}&limit=${limit}`, {
    headers: {
      'Content-Type': 'application/json',
      Authorization: `Bearer ${session!.accessToken}`,
    },
  });
  if (res.ok) {
    const json = await res.json();
    permissionsData = json.data?.items || [];
    totalItems = json.data?.pagination_info?.total_items || 0;
    totalPages = json.data?.pagination_info?.total_pages || 1;
  } else {
    loadError = true;
  }
} catch (_) {
  loadError = true;
}
---

<AppLayout
  title="Permissions — Diva"
  heading="Permissions"
  description="Manage permission definitions."
>
  <PermissionsManager
    initialPermissions={permissionsData}
    initialPage={currentPage}
    initialTotalPages={totalPages}
    initialTotalItems={totalItems}
    loadError={loadError}
    client:load
  />
</AppLayout>
