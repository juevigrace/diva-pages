---
import AppLayout from '@layouts/AppLayout.astro';
import HealthView from '@components/app/HealthView';

import { t } from '@lib/i18n/t';

const { session } = Astro.locals;
const isVerified = session!.isVerified;
---

<AppLayout
  title={t('page.health.title', Astro.locals.lang)}
  heading="System Health"
  description={t('page.health.desc', Astro.locals.lang)}
>
  <HealthView isVerified={isVerified} lang={Astro.locals.lang} client:load />
</AppLayout>
