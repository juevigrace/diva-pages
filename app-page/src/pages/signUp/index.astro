---
import AuthLayout from '@layouts/AuthLayout.astro';
import SignUpForm from '@components/auth/SignUpForm';

const errorMessage = Astro.url.searchParams.get('error');
if (Astro.url.searchParams.get('ok') === 'true') {
  return Astro.redirect('/');
}
---

<AuthLayout title="Create Account — Diva" description="Get started with your free Diva Pages account.">
  {errorMessage && (
    <div class="border-destructive/50 bg-destructive/10 text-destructive mx-auto mb-5 max-w-md rounded-lg border px-4 py-3 text-sm">
      {errorMessage}
    </div>
  )}
  <SignUpForm client:load />
</AuthLayout>
