---
export const prerender = true;
import { t } from '@lib/i18n/t';
import Layout from '@layouts/Layout.astro';
---

<Layout title={t('page.notFound.title', Astro.locals.lang)} description={t('page.notFound.desc', Astro.locals.lang)}>
  <div class="flex min-h-[60vh] flex-col items-center justify-center px-6">
    <div
      class="bg-primary text-primary-foreground flex h-16 w-16 items-center justify-center rounded-2xl text-2xl font-bold"
    >
      D
    </div>
    <h1 class="mt-6 text-4xl font-bold tracking-tight">{t('docs.pageNotFound', Astro.locals.lang)}</h1>
    <p class="text-muted-foreground mt-3 text-center text-lg">
      {t('docs.pageNotFoundDesc', Astro.locals.lang)}
    </p>
    <a
      href="/"
      class="bg-primary text-primary-foreground hover:bg-primary/90 mt-8 inline-flex h-10 items-center justify-center rounded-md px-6 text-sm font-medium shadow transition-colors"
    >
      {t('docs.goHome', Astro.locals.lang)}
    </a>
  </div>
</Layout>
