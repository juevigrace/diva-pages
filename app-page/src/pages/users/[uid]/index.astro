---
import AppLayout from '@layouts/AppLayout.astro';
import UserDetailContent from '@components/app/UserDetailContent';
import { API_BASE_URL } from 'astro:env/server';

const { session } = Astro.locals;
const { uid } = Astro.params;

let user: Record<string, any> | null = null;
let profile: Record<string, any> | null = null;
let permissions: Record<string, any>[] | null = null;
let sessions: Record<string, any>[] | null = null;
let actions: Record<string, any>[] | null = null;

try {
  const userRes = await fetch(`${API_BASE_URL}/api/user/${uid}`, {
    headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${session!.accessToken}` },
  });
  if (userRes.ok) { const j = await userRes.json(); user = j.data; }
} catch (_) {}

try {
  const profRes = await fetch(`${API_BASE_URL}/api/user/${uid}/profile`, {
    headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${session!.accessToken}` },
  });
  if (profRes.ok) { const j = await profRes.json(); profile = j.data; }
} catch (_) {}

try {
  const permRes = await fetch(`${API_BASE_URL}/api/user/${uid}/permissions/`, {
    headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${session!.accessToken}` },
  });
  if (permRes.ok) { const j = await permRes.json(); permissions = j.data; }
} catch (_) {}

try {
  const sessRes = await fetch(`${API_BASE_URL}/api/user/${uid}/sessions`, {
    headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${session!.accessToken}` },
  });
  if (sessRes.ok) { const j = await sessRes.json(); sessions = j.data; }
} catch (_) {}

try {
  const actRes = await fetch(`${API_BASE_URL}/api/user/${uid}/actions/`, {
    headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${session!.accessToken}` },
  });
  if (actRes.ok) { const j = await actRes.json(); actions = j.data; }
} catch (_) {}
---

<AppLayout
  title={user ? `${user.username} — Diva` : 'User — Diva'}
  heading={user?.username || 'User'}
  description="User details and management."
>
  <UserDetailContent
    uid={uid!}
    user={user}
    profile={profile}
    permissions={permissions}
    sessions={sessions}
    actions={actions}
    client:load
  />
</AppLayout>
