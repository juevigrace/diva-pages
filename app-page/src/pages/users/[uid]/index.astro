---
import AppLayout from '@layouts/AppLayout.astro';
import UserDetailContent from '@components/app/UserDetailContent';
import { apiFetch } from '@api/lib/fetch';

const { session } = Astro.locals;
const { uid: currentUserId } = session!;
const { uid } = Astro.params;

let currentUserRole = '';
let user: Record<string, any> | null = null;
let profile: Record<string, any> | null = null;
let permissions: Record<string, any>[] | null = null;
let sessions: Record<string, any>[] | null = null;
let actions: Record<string, any>[] | null = null;
let allPermissions: Record<string, any>[] = [];

try {
  const curRes = await apiFetch(`/api/user/${currentUserId}`, { token: session!.accessToken });
  if (curRes.ok) { currentUserRole = curRes.json.data?.role || ''; }
} catch (_) {}

try {
  const userRes = await apiFetch(`/api/user/${uid}`, { token: session!.accessToken });
  if (userRes.ok) { user = userRes.json.data; }
} catch (_) {}

try {
  const permRes = await apiFetch(`/api/permissions/?limit=100`, { token: session!.accessToken });
  if (permRes.ok) { allPermissions = permRes.json.data?.items || []; }
} catch (_) {}

try {
  const profRes = await apiFetch(`/api/user/${uid}/profile`, { token: session!.accessToken });
  if (profRes.ok) { profile = profRes.json.data; }
} catch (_) {}

try {
  const permRes = await apiFetch(`/api/user/${uid}/permissions/`, { token: session!.accessToken });
  if (permRes.ok) { permissions = permRes.json.data; }
} catch (_) {}

try {
  const sessRes = await apiFetch(`/api/user/${uid}/sessions`, { token: session!.accessToken });
  if (sessRes.ok) { sessions = sessRes.json.data; }
} catch (_) {}

try {
  const actRes = await apiFetch(`/api/user/${uid}/actions/`, { token: session!.accessToken });
  if (actRes.ok) { actions = actRes.json.data; }
} catch (_) {}
---

<AppLayout
  title={user ? `${user.username} — Diva` : 'User — Diva'}
  heading={user?.username || 'User'}
  description="User details and management."
>
  <UserDetailContent
    uid={uid!}
    user={user}
    profile={profile}
    permissions={permissions}
    sessions={sessions}
    actions={actions}
    allPermissions={allPermissions}
    currentUserRole={currentUserRole}
    client:load
  />
</AppLayout>
