---
import AppLayout from '@layouts/AppLayout.astro';
import UsersTable from '@components/app/UsersTable.astro';
---

<AppLayout
  title="Users — Diva"
  heading="Users"
  description="Manage your Diva Pages team members and their permissions."
>
  <div class="mb-6 flex items-center justify-between">
    <p class="text-muted-foreground text-sm">Manage your team members and their permissions.</p>
    <a
      href="/signUp"
      class="bg-primary text-primary-foreground hover:bg-primary/90 inline-flex h-9 items-center justify-center rounded-md px-4 py-2 text-sm font-medium shadow transition-colors"
    >
      <svg
        class="mr-2 h-4 w-4"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"></path>
      </svg>
      Add user
    </a>
  </div>
  <UsersTable />
</AppLayout>
