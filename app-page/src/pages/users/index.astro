---
import AppLayout from '@layouts/AppLayout.astro';
import UsersManager from '@components/app/UsersManager';
import { apiFetch } from '@api/lib/fetch';
import { t } from '@lib/i18n/t';

const { session } = Astro.locals;
const uid = session!.userId;
const isVerified = session!.isVerified;
const currentUserRole = session!.role;

const url = new URL(Astro.request.url);
const currentPage = parseInt(url.searchParams.get('page') || '1', 10);
const limit = 10;

let usersData: Record<string, any>[] = [];
let totalItems = 0;
let totalPages = 1;
let loadError = false;

if (isVerified) {
  try {
    const res = await apiFetch(`/api/user/?page=${currentPage}&limit=${limit}`, { token: session!.accessToken });
    if (res.ok) {
      usersData = res.json.data?.items || [];
      totalItems = res.json.data?.pagination_info?.total_items || 0;
      totalPages = res.json.data?.pagination_info?.total_pages || 1;
    } else {
      loadError = true;
    }
  } catch (_) {
    loadError = true;
  }
}
---

<AppLayout
  title={t('page.users.title', Astro.locals.lang)}
  heading="Users"
  description={t('page.users.desc', Astro.locals.lang)}
>
  <UsersManager
    initialUsers={usersData}
    initialPage={currentPage}
    initialTotalPages={totalPages}
    initialTotalItems={totalItems}
    loadError={loadError}
    isVerified={isVerified}
    currentUserRole={currentUserRole}
    lang={Astro.locals.lang}
    client:load
  />
</AppLayout>
