---
export const prerender = true;
import LandingLayout from '@layouts/LandingLayout.astro';
import Hero from '@components/landing/Hero.astro';
import Features from '@components/landing/Features.astro';
import PricingCards from '@components/landing/PricingCards.astro';
import CtaSection from '@components/landing/CtaSection.astro';
import { t } from '@lib/i18n/t';
---

<LandingLayout
  title={t('page.home.title', Astro.locals.lang)}
  description={t('page.home.desc', Astro.locals.lang)}
>
  <Hero />
  <Features />
  <PricingCards />
  <CtaSection />
</LandingLayout>
