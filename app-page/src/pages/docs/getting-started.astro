---
import DocsLayout from '../../layouts/DocsLayout.astro';
import TocSidebar from '../../components/docs/TocSidebar.astro';
import CodeBlock from '../../components/docs/CodeBlock.astro';
---

<DocsLayout title="Getting Started — Diva Docs" description="Learn how to set up Diva Pages in your project and start building.">
  <div class="flex">
    <main class="max-w-3xl min-w-0 flex-1">
      <h1 id="introduction" class="text-4xl font-bold tracking-tight">Getting Started</h1>
      <p class="text-muted-foreground mt-4 text-lg">
        Learn how to set up Diva Pages in your project and start building.
      </p>

      <h2 id="installation" class="mt-12 text-2xl font-bold tracking-tight">Installation</h2>
      <p class="text-muted-foreground mt-4 leading-relaxed">
        Diva Pages is available as a workspace package. Add it to your Astro project:
      </p>
      <div class="mt-4">
        <CodeBlock code="bun add diva-ui@workspace:*" lang="bash" />
      </div>

      <h3 id="quick-start" class="mt-8 text-xl font-semibold tracking-tight">Quick Start</h3>
      <p class="text-muted-foreground mt-3 leading-relaxed">
        Once installed, import the Layout and start using components in your pages:
      </p>
      <div class="mt-4">
        <CodeBlock
          code={`---
import Layout from '../layouts/Layout.astro';
---

<Layout title="My Page">
  <h1>Hello, Diva!</h1>
</Layout>`}
          lang="astro"
        />
      </div>

      <h3 id="project-structure" class="mt-8 text-xl font-semibold tracking-tight">
        Project Structure
      </h3>
      <p class="text-muted-foreground mt-3 leading-relaxed">
        A typical Diva Pages project looks like this:
      </p>
      <div class="mt-4">
        <CodeBlock
          code={`my-project/
├── app-page/          # Dashboard, docs, landing pages
├── lib/
│   ├── diva-ui/       # Shared component library
│   └── diva-types/    # Shared TypeScript types
└── package.json`}
          lang="text"
        />
      </div>

      <div class="border-border bg-card mt-12 rounded-lg border p-6">
        <p class="text-sm font-medium">💡 Next steps</p>
        <p class="text-muted-foreground mt-2 text-sm">
          Browse the <a
            href="/docs/components"
            class="text-primary hover:text-primary/80 underline underline-offset-4">Components</a
          > guide to see what's available.
        </p>
      </div>
    </main>
    <TocSidebar
      headings={[
        { id: 'introduction', label: 'Introduction', level: 1 },
        { id: 'installation', label: 'Installation', level: 2 },
        { id: 'quick-start', label: 'Quick Start', level: 3 },
        { id: 'project-structure', label: 'Project Structure', level: 3 },
      ]}
    />
  </div>
</DocsLayout>
